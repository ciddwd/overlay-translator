<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- :llama-android 的 minSdk=33（来自 ggml-org/llama.cpp 上游硬要求）。
         屏译 :app 的 minSdk=26 不动；端侧 LLM 翻译运行时按 Build.VERSION.SDK_INT >= 33
         判断可用性，低版本系统下 LOCAL_HUNYUAN_MT / LOCAL_SAKURA 入口在设置里隐藏并禁用。 -->
    <uses-sdk tools:overrideLibrary="com.arm.aichat" />

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- ML Kit 模型自动下载 -->
    <queries>
        <package android:name="com.google.android.gms" />
        <package android:name="moe.shizuku.privileged.api" />
        <package android:name="moe.shizuku.api" />
    </queries>

    <application
        android:name=".GameOcrApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:localeConfig="@xml/locales_config"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.GameOcr"
        tools:targetApi="35">

        <!-- 主界面 -->
        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.GameOcr">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 透明 Activity：用于接 MediaProjection 系统授权回调 -->
        <activity
            android:name=".capture.MediaProjectionRequestActivity"
            android:exported="false"
            android:theme="@style/Theme.GameOcr.Transparent"
            android:excludeFromRecents="true"
            android:noHistory="true" />

        <!-- 区域选择 Activity：全屏拉框 -->
        <activity
            android:name=".capture.RegionPickerActivity"
            android:exported="false"
            android:theme="@style/Theme.GameOcr.Transparent"
            android:excludeFromRecents="true"
            android:noHistory="true" />

        <!-- 系统「文字选中」菜单入口：用户在任意 App 长按文字选词，系统菜单会列出本项。
             无 UI，立即 finish；翻译走 application scope；结果浮卡显示在原 App 上层。 -->
        <activity
            android:name=".translate.ProcessTextTranslateActivity"
            android:exported="true"
            android:label="@string/process_text_label"
            android:icon="@drawable/ic_menu_word_select"
            android:theme="@style/Theme.GameOcr.Transparent"
            android:excludeFromRecents="true"
            android:noHistory="true">
            <intent-filter>
                <action android:name="android.intent.action.PROCESS_TEXT" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>
        </activity>

        <!-- 截屏前台服务：mediaProjection 用于默认截屏；specialUse 用于 Shizuku 路径 -->
        <!-- configChanges 必须包含 orientation+screenSize+screenLayout+smallestScreenSize：
             旋转屏幕时由 Service 自己接 onConfigurationChanged，按比例重算悬浮窗位置 +
             updateViewLayout。否则旋转后悬浮窗位置会废（竖屏 y=200 横屏可能落到状态栏后）。 -->
        <service
            android:name=".service.CaptureService"
            android:exported="false"
            android:foregroundServiceType="mediaProjection|specialUse"
            android:configChanges="orientation|screenSize|screenLayout|smallestScreenSize">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Shizuku-based on-demand screen capture for OCR translation" />
        </service>

        <!-- Shizuku provider：用于让 Shizuku 服务把 IBinder 绑过来 -->
        <provider
            android:name="rikka.shizuku.ShizukuProvider"
            android:authorities="${applicationId}.shizuku"
            android:exported="true"
            android:multiprocess="false"
            android:permission="android.permission.INTERACT_ACROSS_USERS_FULL"
            tools:ignore="ExportedContentProvider" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.logfileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/log_file_paths" />
        </provider>

        <!-- 可选无障碍服务：音量键触发器（仅用户在设置里启用后生效） -->
        <service
            android:name=".trigger.GameOcrAccessibilityService"
            android:exported="false"
            android:label="@string/a11y_summary"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/a11y_config" />
        </service>

        <!-- ML Kit 端侧模型自动下载 -->
        <meta-data
            android:name="com.google.mlkit.vision.DEPENDENCIES"
            android:value="ocr,ocr_japanese,ocr_chinese" />

        <!-- MIUI / HyperOS 特殊配置：允许 overlay window 在横屏延伸到 long-edge cutout
             区域，否则系统默认 letterbox 让 window 不能覆盖 cutout，左边露物理屏黑条。
             不是 Google 标准 API（PhoneWindowManager 硬限制），仅小米 OEM 提供放开通道。 -->
        <meta-data
            android:name="notch.config"
            android:value="portrait|landscape" />

    </application>

</manifest>
